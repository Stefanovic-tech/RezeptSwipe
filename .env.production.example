# Production env vorlage fuer rezept.krinulovic.ch (Windows Server + Nginx + PM2)
NODE_ENV=production
APP_PORT=3015
APP_BASE_URL=https://rezept.krinulovic.ch
APP_PUBLIC_BASE_URL=https://rezept.krinulovic.ch

# MySQL auf Prod-Server
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=rezeptswipe
DB_PASSWORD=replace-strong-prod-password
DB_NAME=rezeptswipe

# Auth: starkes Random-Secret (mind. 32 Zeichen) auf jedem Server eindeutig
AUTH_SECRET=replace-with-strong-random-secret-min-32-chars
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=1

# Bootstrap (nur fuer Erst-Setup; danach Werte leer setzen oder Skript nicht erneut ausfuehren)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_HOUSEHOLD_NAME=Haushalt
BOOTSTRAP_INVITE_CODE=
BOOTSTRAP_SEED_DEFAULT_RECIPES=1
BOOTSTRAP_FORCE_RESET_DB=0

# Gemini (fuer npm run seed / TheMealDB-Uebersetzung; nicht zur Laufzeit in Next.js noetig)
# scripts/_env.mjs laedt .env.local + .env; bei NODE_ENV=production zusaetzlich .env.production(.local).
# Zusaetzlich: falls GEMINI_API_KEY in .env leer ist, wird .env.production als Fallback eingelesen.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Recipe source (TheMealDB; Seed schreibt in recipe_cache)
THEMEALDB_BASE_URL=https://www.themealdb.com/api/json/v1/1
MEALDB_RANDOM_PER_RUN=24
MEALDB_REQUEST_DELAY_MS=150

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
