# Environment
NODE_ENV=development
APP_PORT=3015
APP_BASE_URL=http://localhost:3015
APP_PUBLIC_BASE_URL=http://localhost:3015

# DB (XAMPP MySQL standardmaessig auf 3306, root ohne Passwort)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rezeptswipe

# Auth: HS256 JWT secret (mind. 32 Zeichen)
AUTH_SECRET=replace-with-32-char-random-secret-please
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=0

# Bootstrap (legt initialen Admin + Haushalt + Invite an)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_HOUSEHOLD_NAME=Haushalt
BOOTSTRAP_INVITE_CODE=STARTER1
BOOTSTRAP_SEED_DEFAULT_RECIPES=1
BOOTSTRAP_FORCE_RESET_DB=0

# Gemini (wird von npm run seed / scripts/mealdb-sync.mjs genutzt)
# Hinweis: scripts/_env.mjs laedt .env.local + .env; bei NODE_ENV=production zusaetzlich .env.production(.local).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Recipe source (TheMealDB; wird beim Seed in recipe_cache geschrieben)
THEMEALDB_BASE_URL=https://www.themealdb.com/api/json/v1/1
# Anzahl random.php-Abrufe pro Seed (0 = aus)
MEALDB_RANDOM_PER_RUN=24
# Pause in ms zwischen TheMealDB-Requests (Rate-Limit freundlich)
MEALDB_REQUEST_DELAY_MS=150

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
