# Environment
NODE_ENV=development
APP_PORT=3015
APP_BASE_URL=http://localhost:3015
APP_PUBLIC_BASE_URL=http://localhost:3015

# DB (XAMPP MySQL standardmaessig auf 3306, root ohne Passwort)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=rezeptswipe

# Auth: HS256 JWT secret (mind. 32 Zeichen)
AUTH_SECRET=replace-with-32-char-random-secret-please
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=0

# Bootstrap (legt initialen Admin + Haushalt + Invite an)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_HOUSEHOLD_NAME=Haushalt
BOOTSTRAP_INVITE_CODE=STARTER1
BOOTSTRAP_SEED_DEFAULT_RECIPES=1
BOOTSTRAP_FORCE_RESET_DB=0

# Uebersetzung: Lokales LLM via Ollama (bevorzugt). Ollama muss separat laufen.
# Wenn OLLAMA_MODEL gesetzt ist, nutzt sowohl `npm run seed` als auch die App
# (Lazy-Uebersetzung beim Oeffnen eines Rezepts) Ollama. Ohne gesetztes Modell
# wird Gemini als Fallback verwendet, sofern GEMINI_API_KEY vorhanden ist.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
# HTTP-Timeout fuer /api/chat (ms). Bei langsamer CPU / grossen Rezepten eher 600000.
OLLAMA_TIMEOUT_MS=300000
# Max. generierte Tokens (weniger = schneller fertig, zu klein = JSON abgeschnitten).
OLLAMA_NUM_PREDICT=6144
# CPU-Threads pro Inferenz (0 = Ollama-Default). Auf geteiltem Server z. B. 2 oder 4.
OLLAMA_NUM_THREAD=0
# 1 = nur eine Uebersetzung gleichzeitig pro App-Prozess (weniger CPU-Spitzen). 0 = parallel moeglich.
OLLAMA_SERIALIZE=1

# Gemini (Fallback fuer Uebersetzung; nur aktiv, wenn OLLAMA_MODEL leer ist
# oder Ollama im Seed-Lauf einen Fehler liefert).
# Hinweis: scripts/_env.mjs laedt .env.local + .env; bei NODE_ENV=production zusaetzlich .env.production(.local).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Pause zwischen Gemini-Uebersetzungen (Free Tier / Rate Limits). Bei 429 automatisches Retry mit Backoff.
GEMINI_REQUEST_DELAY_MS=3500
GEMINI_MAX_RETRIES=8
GEMINI_BACKOFF_CAP_MS=120000

# Recipe source (TheMealDB; wird beim Seed in recipe_cache geschrieben)
THEMEALDB_BASE_URL=https://www.themealdb.com/api/json/v1/1
# Anzahl random.php-Abrufe pro Seed (0 = aus)
MEALDB_RANDOM_PER_RUN=24
# Pause in ms zwischen TheMealDB-Requests (Rate-Limit freundlich)
MEALDB_REQUEST_DELAY_MS=150

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
